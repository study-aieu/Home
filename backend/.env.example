# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/universal_blog_publisher?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV="development"

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR="uploads"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Encryption (for storing provider credentials securely)
ENCRYPTION_KEY="your-32-character-encryption-key-change-this-in-production"

# CORS Origins (comma-separated)
CORS_ORIGIN="http://localhost:8081,exp://192.168.1.100:8081"

# Provider API Keys (Optional - for enhanced features)
# WORDPRESS_COM_CLIENT_ID=""
# WORDPRESS_COM_CLIENT_SECRET=""
# MEDIUM_CLIENT_ID=""
# MEDIUM_CLIENT_SECRET=""
# GHOST_ADMIN_API_URL=""
# CONTENTFUL_MANAGEMENT_TOKEN=""